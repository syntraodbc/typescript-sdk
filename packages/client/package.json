{
  "name": "@syntraodbc/client",
  "version": "0.1.0",
  "description": "Zero-config typed TypeScript client for Syntra ODBC. Wraps postgres.js with IntelliSense on every QuickBooks Desktop table and column.",
  "keywords": [
    "quickbooks",
    "quickbooks-desktop",
    "typescript",
    "odbc",
    "syntra",
    "postgres",
    "client",
    "sdk"
  ],
  "homepage": "https://syntraodbc.com/developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/syntraodbc/typescript-sdk.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/syntraodbc/typescript-sdk/issues"
  },
  "author": "Syntra ODBC <support@syntraodbc.com> (https://syntraodbc.com)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"[client] no tests yet\" && exit 0",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@syntraodbc/drizzle-schema": "workspace:^",
    "postgres": "^3.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
