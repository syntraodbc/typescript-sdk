{
  "name": "@syntraodbc/drizzle-schema",
  "version": "0.1.0",
  "description": "Typed Drizzle ORM schema for every QuickBooks Desktop table exposed by Syntra ODBC. Full IntelliSense, zero hand-written types.",
  "keywords": [
    "quickbooks",
    "quickbooks-desktop",
    "drizzle",
    "drizzle-orm",
    "typescript",
    "odbc",
    "syntra",
    "postgres",
    "orm",
    "schema"
  ],
  "homepage": "https://syntraodbc.com/developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/syntraodbc/typescript-sdk.git",
    "directory": "packages/drizzle-schema"
  },
  "bugs": {
    "url": "https://github.com/syntraodbc/typescript-sdk/issues"
  },
  "author": "Syntra ODBC <support@syntraodbc.com> (https://syntraodbc.com)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate": "node ../../scripts/emit-drizzle.mjs",
    "build": "pnpm run generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"[drizzle-schema] no tests yet\" && exit 0",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.33.0 || ^0.34.0 || ^0.35.0 || ^0.36.0 || ^0.37.0 || ^0.38.0 || ^0.39.0 || ^0.40.0 || ^0.41.0 || ^0.42.0 || ^0.43.0 || ^0.44.0 || ^0.45.0"
  },
  "devDependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
